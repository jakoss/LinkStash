LINKSTASH_SERVER_IMAGE=ghcr.io/replace-with-owner/linkstash-server:latest
HOST_PORT=8080
PORT=8080
DB_URL=jdbc:sqlite:/data/linkstash.db
SESSION_SECRET=replace-me
TOKEN_HASHING_SECRET=replace-me
RAINDROP_TOKEN_ENCRYPTION_KEY=replace-me
LINKSTASH_ROOT_COLLECTION_TITLE=LinkStash
LINKSTASH_DEFAULT_SPACE_TITLE=Inbox
# Optional:
# SESSION_COOKIE_NAME=linkstash_session
# SESSION_COOKIE_SECURE=false
# SESSION_TTL_SECONDS=2592000
# Leave CORS unset for the default same-origin deployment.
# Set it only when another web origin needs to call the API.
# CORS_ALLOWED_ORIGINS=https://linkstash.app,http://localhost:8081,http://127.0.0.1:8081
# CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-Id,X-CSRF-Token
# CORS_EXPOSED_HEADERS=X-Request-Id
# CORS_ALLOW_CREDENTIALS=true
# CSRF_HEADER_NAME=X-CSRF-Token
